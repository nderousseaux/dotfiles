# ~/.zshrc — Configuration interactive de Zsh

# ---------------------------------------------------------------------------
# PATH
# ---------------------------------------------------------------------------
export PATH="$HOME/bin:$PATH"

# ---------------------------------------------------------------------------
# Éditeur
# ---------------------------------------------------------------------------
export EDITOR="vim"
export VISUAL="vim"

# ---------------------------------------------------------------------------
# Historique
# ---------------------------------------------------------------------------
HISTFILE="$HOME/.zsh_history"
HISTSIZE=10000
SAVEHIST=10000
setopt SHARE_HISTORY          # Partage l'historique entre sessions
setopt HIST_IGNORE_DUPS       # Ignore les doublons consécutifs
setopt HIST_IGNORE_SPACE      # Ignore les commandes précédées d'un espace

# ---------------------------------------------------------------------------
# Options
# ---------------------------------------------------------------------------
setopt AUTO_CD                # Tape un dossier pour y aller directement
setopt CORRECT                # Suggestions de correction de commandes

# ---------------------------------------------------------------------------
# Complétion
# ---------------------------------------------------------------------------
autoload -Uz compinit && compinit
zstyle ':completion:*' menu select
zstyle ':completion:*' matcher-list 'm:{a-z}={A-Z}'  # Insensible à la casse

# ---------------------------------------------------------------------------
# Prompt
# ---------------------------------------------------------------------------
autoload -Uz vcs_info
precmd() { vcs_info }
zstyle ':vcs_info:git:*' formats ' (%b)'
setopt PROMPT_SUBST
PROMPT='%F{cyan}%~%f%F{yellow}${vcs_info_msg_0_}%f %# '

# ---------------------------------------------------------------------------
# ZLE — édition de la ligne de commande
# ---------------------------------------------------------------------------
# Ctrl+X Ctrl+E : ouvrir la commande en cours dans $EDITOR
autoload -Uz edit-command-line
zle -N edit-command-line
bindkey '^x^e' edit-command-line

# ---------------------------------------------------------------------------
# SSH — compatibilité terminfo
# ---------------------------------------------------------------------------
# Ghostty utilise TERM=xterm-ghostty, absent sur la plupart des serveurs.
# On force xterm-256color pour les connexions SSH.
ssh() { TERM=xterm-256color command ssh "$@" }

# ---------------------------------------------------------------------------
# Alias
# ---------------------------------------------------------------------------
alias ls='ls --color=auto'
alias ll='ls -lh'
alias la='ls -lah'
alias grep='grep --color=auto'
alias ..='cd ..'
alias ...='cd ../..'

# Alias spéciaux
alias bssh='ssh -o ServerAliveInterval=10 -o ServerAliveCountMax=3 -t bastion --'

# ---------------------------------------------------------------------------
# fzf — fuzzy finder
# ---------------------------------------------------------------------------
if command -v fzf &>/dev/null; then
  # Intégration shell (key bindings + complétion fuzzy)
  source <(fzf --zsh)

  # Options par défaut
  export FZF_DEFAULT_OPTS="\
    --height=40% \
    --layout=reverse \
    --border \
    --info=inline \
    --bind='?:toggle-preview'"

  # Utiliser fd si disponible pour un listing plus rapide
  if command -v fd &>/dev/null; then
    export FZF_DEFAULT_COMMAND='fd --type f --hidden --follow --exclude .git'
    export FZF_CTRL_T_COMMAND="$FZF_DEFAULT_COMMAND"
    export FZF_ALT_C_COMMAND='fd --type d --hidden --follow --exclude .git'
  fi

  # Aperçu : fichiers avec bat/cat, dossiers avec tree/ls
  if command -v bat &>/dev/null; then
    _fzf_file_preview='bat --color=always --style=plain --line-range :200 {}'
  else
    _fzf_file_preview='cat {}'
  fi
  if command -v tree &>/dev/null; then
    _fzf_dir_preview='tree -C {} | head -50'
  else
    _fzf_dir_preview='ls -la {}'
  fi
  export FZF_CTRL_T_OPTS="--preview '[ -d {} ] && ${_fzf_dir_preview} || ${_fzf_file_preview}'"
  export FZF_ALT_C_OPTS="--preview '${_fzf_dir_preview}'"
fi
