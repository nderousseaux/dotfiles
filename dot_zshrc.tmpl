# ~/.zshrc — Configuration interactive de Zsh

# ---------------------------------------------------------------------------
# tmux — lancement automatique (une session par fenêtre terminal)
# ---------------------------------------------------------------------------
# Comportement :
#   - Chaque nouvelle fenêtre terminal crée une nouvelle session tmux.
#   - Fermer la fenêtre (quelle que soit la méthode) tue la session.
#   - Détacher manuellement (C-b d) laisse la session vivante.
#   - Un processus gardien surveille ce shell ; dès qu'il meurt, il tue la
#     session tmux associée — pas de dépendance à SIGHUP.
if command -v tmux &>/dev/null && [[ -z "$TMUX" ]] && [[ $- == *i* ]] && [[ "$TERM_PROGRAM" != "vscode" ]]; then
  _TMUX_SESSION="win-$$"
  _TMUX_SHELL_PID=$$

  # Gardien en arrière-plan : immune à SIGHUP, surveille le shell parent.
  # Dès que ce shell disparaît → tue la session.
  (
    trap '' HUP
    while kill -0 "$_TMUX_SHELL_PID" 2>/dev/null; do
      sleep 1
    done
    tmux kill-session -t "$_TMUX_SESSION" 2>/dev/null
  ) &!
  _TMUX_WATCHER_PID=$!

  # Lance tmux (bloquant jusqu'à détachement ou fermeture de toutes les fenêtres)
  tmux new-session -s "$_TMUX_SESSION"

  if tmux has-session -t "$_TMUX_SESSION" 2>/dev/null; then
    # Session toujours vivante → détachement volontaire → annuler le gardien
    kill "$_TMUX_WATCHER_PID" 2>/dev/null
  else
    # Toutes les fenêtres tmux fermées → fermer le terminal aussi
    kill "$_TMUX_WATCHER_PID" 2>/dev/null
    unset _TMUX_SESSION _TMUX_SHELL_PID _TMUX_WATCHER_PID
    exit 0
  fi

  unset _TMUX_SESSION _TMUX_SHELL_PID _TMUX_WATCHER_PID
fi

# ---------------------------------------------------------------------------
# PATH
# ---------------------------------------------------------------------------
export PATH="$HOME/bin:$PATH"

# ---------------------------------------------------------------------------
# Éditeur
# ---------------------------------------------------------------------------
export EDITOR="vim"
export VISUAL="vim"

# ---------------------------------------------------------------------------
# Oh My Zsh — configuration minimale
# ---------------------------------------------------------------------------
export ZSH="$HOME/.oh-my-zsh"
export ZSH_CUSTOM="$HOME/.oh-my-zsh-custom"
ZSH_THEME="minimal-nd"

# Pas de mise à jour auto (géré par chezmoi)
zstyle ':omz:update' mode disabled

# Plugins : complétion et alias utiles, rien de plus
plugins=(
  git              # alias git (ga, gco, gst…)
  docker           # complétion docker
  kubectl          # complétion kubectl + alias (k)
  terraform        # complétion terraform
)

source "$ZSH/oh-my-zsh.sh"

# ---------------------------------------------------------------------------
# Historique (complète / surcharge les réglages d'omz)
# ---------------------------------------------------------------------------
HISTFILE="$HOME/.zsh_history"
HISTSIZE=10000
SAVEHIST=10000
setopt SHARE_HISTORY          # Partage l'historique entre sessions
setopt HIST_IGNORE_DUPS       # Ignore les doublons consécutifs
setopt HIST_IGNORE_SPACE      # Ignore les commandes précédées d'un espace

# ---------------------------------------------------------------------------
# Options
# ---------------------------------------------------------------------------
setopt AUTO_CD                # Tape un dossier pour y aller directement
setopt CORRECT                # Suggestions de correction de commandes

# ---------------------------------------------------------------------------
# Complétion (affinements au-dessus d'omz)
# ---------------------------------------------------------------------------
zstyle ':completion:*' matcher-list 'm:{a-z}={A-Z}'  # Insensible à la casse

# ---------------------------------------------------------------------------
# ZLE — édition de la ligne de commande
# ---------------------------------------------------------------------------
# Ctrl+X Ctrl+E : ouvrir la commande en cours dans $EDITOR
autoload -Uz edit-command-line
zle -N edit-command-line
bindkey '^x^e' edit-command-line

# ---------------------------------------------------------------------------
# SSH — compatibilité terminfo
# ---------------------------------------------------------------------------
# Ghostty utilise TERM=xterm-ghostty, absent sur la plupart des serveurs.
# On force xterm-256color pour les connexions SSH.
ssh() { TERM=xterm-256color command ssh "$@" }

# ---------------------------------------------------------------------------
# Alias
# ---------------------------------------------------------------------------
alias ls='ls --color=auto'
alias ll='ls -lh'
alias la='ls -lah'
alias grep='grep --color=auto'

# eza — remplacement moderne de ls (activé seulement si eza est installé)
if command -v eza &>/dev/null; then
  alias es='eza --icons --group-directories-first'
  alias el='eza -l --icons --time-style=relative --group-directories-first'
  alias ea='eza -la --git --icons --time-style=relative --group-directories-first'
  alias et='eza -la -T --git --icons --time-style=relative --group-directories-first'
fi
alias ..='cd ..'
alias ...='cd ../..'
alias v='vim'

# Alias spéciaux
alias bssh='ssh -o ServerAliveInterval=10 -o ServerAliveCountMax=3 -t bastion --'
alias dpda="docker run --rm --volume "$PWD":/mnt --workdir /mnt -u 1000:1000 -i -t pdagog/refc"

# ---------------------------------------------------------------------------
# autojump — navigation rapide par historique
# ---------------------------------------------------------------------------
if command -v autojump &>/dev/null; then
  _aj_script="$(brew --prefix)/etc/profile.d/autojump.sh"

  # Évite les conflits au rechargement du shell
  unalias j 2>/dev/null

  # Charge autojump une seule fois
  if [[ -z "${_AUTOJUMP_LOADED:-}" && -f "$_aj_script" ]]; then
    source "$_aj_script"
    export _AUTOJUMP_LOADED=1
  fi
fi

# ---------------------------------------------------------------------------
# zsh-autosuggestions — suggestions à la frappe (style fish)
# ---------------------------------------------------------------------------
_zas_script="$(brew --prefix)/share/zsh-autosuggestions/zsh-autosuggestions.zsh"
if [[ -f "$_zas_script" ]]; then
  source "$_zas_script"
  ZSH_AUTOSUGGEST_HIGHLIGHT_STYLE="fg=8"       # Gris discret
  ZSH_AUTOSUGGEST_STRATEGY=(history completion) # Historique puis complétion
  ZSH_AUTOSUGGEST_BUFFER_MAX_SIZE=40            # Pas de suggestion sur les longues lignes
  bindkey '^ ' autosuggest-accept               # Ctrl+Espace pour accepter
fi

# ---------------------------------------------------------------------------
# fzf — fuzzy finder
# ---------------------------------------------------------------------------
if command -v fzf &>/dev/null; then
  # Intégration shell (key bindings + complétion fuzzy)
  source <(fzf --zsh)

  # Options par défaut
  export FZF_DEFAULT_OPTS="\
    --height=40% \
    --layout=reverse \
    --border \
    --info=inline \
    --bind='?:toggle-preview'"

  # Utiliser fd si disponible pour un listing plus rapide
  if command -v fd &>/dev/null; then
    _fzf_excludes=(
      --exclude .git
      --exclude node_modules
      --exclude .venv
      --exclude venv
      --exclude .git
      --exclude __pycache__
      --exclude dist
      --exclude build
      --exclude target
      --exclude .DS_Store
      --exclude .cache
      --exclude .next
      --exclude .nuxt
      --exclude vendor
      --exclude coverage
    )
    export FZF_DEFAULT_COMMAND="fd --type f --hidden --follow ${_fzf_excludes[*]}"
    export FZF_CTRL_T_COMMAND="$FZF_DEFAULT_COMMAND"
    export FZF_ALT_C_COMMAND="fd --type d --hidden --follow ${_fzf_excludes[*]}"
  fi

  # Aperçu : fichiers avec bat/cat, dossiers avec tree/ls
  if command -v bat &>/dev/null; then
    _fzf_file_preview='bat --color=always --style=plain --line-range :200 {}'
  else
    _fzf_file_preview='cat {}'
  fi
  if command -v tree &>/dev/null; then
    _fzf_dir_preview='tree -C {} | head -50'
  else
    _fzf_dir_preview='ls -la {}'
  fi
  export FZF_CTRL_T_OPTS="--preview '[ -d {} ] && ${_fzf_dir_preview} || ${_fzf_file_preview}'"
  export FZF_ALT_C_OPTS="--preview '${_fzf_dir_preview}'"
fi

# ---------------------------------------------------------------------------
# zsh-syntax-highlighting — coloration syntaxique (doit être sourcé en dernier)
# ---------------------------------------------------------------------------
_zsh_hl="$(brew --prefix)/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh"
[[ -f "$_zsh_hl" ]] && source "$_zsh_hl"
