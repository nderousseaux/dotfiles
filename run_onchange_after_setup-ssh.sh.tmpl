#!/bin/bash
# Configure le déchiffrement SSH via age
# decrypt_ssh: {{ .decrypt_ssh }}

{{ if .decrypt_ssh -}}
{{ if eq .chezmoi.os "linux" "darwin" -}}

KEY_FILE="$HOME/.config/chezmoi/key.txt"

# Si la clé existe déjà, SSH est déjà géré par chezmoi → rien à faire
if [ -f "$KEY_FILE" ]; then
  exit 0
fi

# --- Phase 2 : la clé n'existe pas encore, on la configure ---

# S'assure que brew est dans le PATH
if [[ -x /opt/homebrew/bin/brew ]]; then
  eval "$(/opt/homebrew/bin/brew shellenv)"
elif [[ -x /usr/local/bin/brew ]]; then
  eval "$(/usr/local/bin/brew shellenv)"
elif [[ -x /home/linuxbrew/.linuxbrew/bin/brew ]]; then
  eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv)"
fi

# Installe age si nécessaire (normalement déjà fait par brew bundle)
if ! command -v age &>/dev/null; then
  echo "🔐 Installation de age..."
  brew install age || { echo "❌ L'installation de age a échoué."; exit 1; }
fi

# Demande la clé age
echo ""
echo "🔑 Clé age requise pour déchiffrer la configuration SSH."
echo "   Collez la clé secrète age (AGE-SECRET-KEY-...) :"
echo ""
read -rp "→ " AGE_KEY

if [[ ! "$AGE_KEY" =~ ^AGE-SECRET-KEY- ]]; then
  echo "❌ Clé invalide (doit commencer par AGE-SECRET-KEY-)"
  exit 1
fi

mkdir -p "$(dirname "$KEY_FILE")"
echo "$AGE_KEY" > "$KEY_FILE"
chmod 600 "$KEY_FILE"
echo "✅ Clé age enregistrée"

# Re-init chezmoi : maintenant que key.txt existe, le template
# active encryption=age et .ssh/ n'est plus ignoré
echo "🔄 Déploiement de la configuration SSH..."
chezmoi init
chezmoi apply --force

echo "✅ Configuration SSH déployée"

{{ end -}}
{{ end -}}
