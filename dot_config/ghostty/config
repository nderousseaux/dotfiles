# ~/.config/ghostty/config — Configuration Ghostty

# ---------------------------------------------------------------------------
# Apparence
# ---------------------------------------------------------------------------
theme = Catppuccin Frappe

font-family = JetBrains Mono
font-size = 13

window-padding-x = 8
window-padding-y = 8,1

window-width = 84
window-height = 24

cursor-style = block
cursor-style-blink = true

# ---------------------------------------------------------------------------
# Shell
# ---------------------------------------------------------------------------
shell-integration = zsh

# ---------------------------------------------------------------------------
# Clavier
# ---------------------------------------------------------------------------
# Envoie des séquences d'échappement pour Alt/Option (requis pour fzf Alt+C, etc.)
# Uniquement Option gauche = Alt, Option droite reste pour les caractères AZERTY (ex: ~)
macos-option-as-alt = left

# Ctrl+L : laisser passer le caractère brut (\x0c) pour que ça fonctionne aussi en SSH
keybind = ctrl+l=unbind

# ---------------------------------------------------------------------------
# Comportement
# ---------------------------------------------------------------------------
mouse-hide-while-typing = true
copy-on-select = false
confirm-close-surface = false
