#!/bin/bash
# Installe Homebrew si non présent

{{ if eq .chezmoi.os "linux" "darwin" -}}

if ! command -v brew &>/dev/null; then
  echo "📦 Installation de Homebrew..."
  /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)" || {
    echo "❌ L'installation de Homebrew a échoué (droits sudo manquants ?)."
    exit 1
  }

  # Ajoute brew au PATH pour la session courante
  if [[ -x /opt/homebrew/bin/brew ]]; then
    eval "$(/opt/homebrew/bin/brew shellenv)"
  elif [[ -x /usr/local/bin/brew ]]; then
    eval "$(/usr/local/bin/brew shellenv)"
  elif [[ -x /home/linuxbrew/.linuxbrew/bin/brew ]]; then
    eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv)"
  fi

  echo "✅ Homebrew installé avec succès"
else
  # S'assure que brew est dans le PATH
  if [[ -x /opt/homebrew/bin/brew ]]; then
    eval "$(/opt/homebrew/bin/brew shellenv)"
  elif [[ -x /usr/local/bin/brew ]]; then
    eval "$(/usr/local/bin/brew shellenv)"
  elif [[ -x /home/linuxbrew/.linuxbrew/bin/brew ]]; then
    eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv)"
  fi
  echo "✅ Homebrew est déjà installé"
fi

{{ if .decrypt_ssh -}}
# age est nécessaire AVANT que chezmoi ne déchiffre les fichiers .age
if ! command -v age &>/dev/null; then
  echo "🔐 Installation de age (chiffrement SSH)..."
  brew install age || {
    echo "❌ L'installation de age a échoué."
    exit 1
  }
  echo "✅ age installé avec succès"
fi
{{ end -}}

{{ end -}}
